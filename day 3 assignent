 create table shop(
	product_name varchar(23) not null,
    product_price varchar(25) 
    
);

insert into shop (product_name) values ('pani poori'),('biriyani'),
('meals');
set sql_safe_updates=0;
update shop set product_price = 150 where product_name = 'pani poori';
update shop set product_price = 250 where product_name = 'biriyani';
update shop set product_price = 100 where product_name = 'meals';

alter table shop add column product_id int;
 
 desc shop;
 select * from shop;

